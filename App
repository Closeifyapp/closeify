<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no"/>
<meta name="apple-mobile-web-app-capable" content="yes"/>
<meta name="apple-mobile-web-app-status-bar-style" content="black-translucent"/>
<meta name="theme-color" content="#04060f"/>
<title>Closeify — AI Sales Coach</title>
<link rel="preconnect" href="https://fonts.googleapis.com"/>
<link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;600;700;800&family=Lora:ital,wght@0,400;1,400&display=swap" rel="stylesheet"/>
<style>
*{box-sizing:border-box;margin:0;padding:0;-webkit-tap-highlight-color:transparent;}
html,body{height:100%;background:#04060f;overflow:hidden;}
#app{height:100%;display:flex;flex-direction:column;max-width:480px;margin:0 auto;position:relative;overflow:hidden;color:#fff;font-family:'Syne',sans-serif;}
::-webkit-scrollbar{width:3px;}
::-webkit-scrollbar-thumb{background:#ffffff18;border-radius:2px;}

/* BACKGROUNDS */
#svg-bg{position:absolute;inset:0;z-index:0;width:100%;height:100%;display:block;}
#bg-overlay{position:absolute;inset:0;z-index:1;background:linear-gradient(to bottom,rgba(4,6,20,0.22) 0%,rgba(4,6,20,0.14) 20%,rgba(4,6,20,0.65) 55%,rgba(4,6,20,0.96) 82%,rgba(4,6,20,1) 100%);}
#neural-bg{position:absolute;inset:0;width:100%;height:100%;opacity:0.18;pointer-events:none;z-index:2;}
.nl{stroke-dasharray:2 3;animation:nDash 6s linear infinite;}
.nn{animation:nPulse 3s ease-in-out infinite;}
@keyframes nDash{to{stroke-dashoffset:-50;}}
@keyframes nPulse{0%,100%{opacity:.3;}50%{opacity:.8;}}
@keyframes scF{0%,100%{opacity:.85;}50%{opacity:1;}}
@keyframes cG{0%,100%{opacity:.45;}50%{opacity:1;}}
@keyframes fC{0%,100%{transform:translateY(0);}50%{transform:translateY(-3px);}}
@keyframes pP{0%,100%{opacity:.6;}50%{opacity:1;}}

/* SPLASH */
#splash{position:absolute;inset:0;z-index:100;background:#04060f;display:flex;flex-direction:column;align-items:center;justify-content:center;transition:opacity 0.6s ease;}
#splash.hide{opacity:0;pointer-events:none;}
.sp-logo{width:88px;height:88px;border-radius:26px;background:linear-gradient(135deg,#ff6b6b,#ffd93d);display:flex;align-items:center;justify-content:center;font-size:42px;box-shadow:0 0 60px rgba(255,107,107,0.5),0 0 120px rgba(255,107,107,0.18);animation:spPop 0.8s cubic-bezier(0.34,1.56,0.64,1) forwards;margin-bottom:26px;}
@keyframes spPop{from{transform:scale(0.2);opacity:0;}to{transform:scale(1);opacity:1;}}
.sp-title{font-size:34px;font-weight:800;background:linear-gradient(90deg,#ff6b6b,#ffd93d);-webkit-background-clip:text;-webkit-text-fill-color:transparent;animation:fU 0.7s 0.4s both;}
.sp-sub{font-size:11px;color:rgba(255,255,255,0.3);letter-spacing:0.2em;margin-top:7px;animation:fU 0.7s 0.6s both;}
.sp-feats{display:flex;flex-direction:column;gap:9px;margin-top:36px;width:250px;animation:fU 0.7s 0.8s both;}
.sp-feat{display:flex;align-items:center;gap:11px;font-size:12.5px;color:rgba(255,255,255,0.48);}
.sp-dot{width:7px;height:7px;border-radius:50%;background:linear-gradient(135deg,#ff6b6b,#ffd93d);flex-shrink:0;}
.sp-btn{margin-top:40px;padding:15px 46px;background:linear-gradient(135deg,#ff6b6b,#ff9500);border:none;border-radius:50px;color:#fff;font-family:'Syne',sans-serif;font-size:15px;font-weight:800;letter-spacing:0.07em;cursor:pointer;box-shadow:0 8px 30px rgba(255,107,107,0.4);animation:fU 0.7s 1s both;transition:transform 0.15s,box-shadow 0.15s;}
.sp-btn:active{transform:scale(0.96);}
.sp-ver{font-size:9px;color:rgba(255,255,255,0.14);margin-top:18px;letter-spacing:0.1em;animation:fU 0.7s 1.1s both;}
@keyframes fU{from{opacity:0;transform:translateY(14px);}to{opacity:1;transform:translateY(0);}}

/* HEADER */
.hdr{display:flex;align-items:center;justify-content:space-between;padding:12px 17px;padding-top:max(12px,env(safe-area-inset-top));background:rgba(4,6,20,0.68);border-bottom:1px solid rgba(255,255,255,0.07);backdrop-filter:blur(24px);-webkit-backdrop-filter:blur(24px);position:relative;z-index:12;flex-shrink:0;}
.logo-wrap{display:flex;align-items:center;gap:9px;}
.logo-mark{width:32px;height:32px;border-radius:9px;background:linear-gradient(135deg,#ff6b6b,#ffd93d);display:flex;align-items:center;justify-content:center;font-size:16px;box-shadow:0 4px 14px rgba(255,107,107,0.4);flex-shrink:0;}
.app-name{font-size:15px;font-weight:800;letter-spacing:0.04em;background:linear-gradient(90deg,#ff6b6b,#ffd93d);-webkit-background-clip:text;-webkit-text-fill-color:transparent;}
.app-sub{font-size:7.5px;color:rgba(255,255,255,0.25);letter-spacing:0.15em;margin-top:1px;}
.hstats{display:flex;gap:12px;}
.hstat{text-align:center;}
.hval{display:block;font-size:14px;font-weight:700;color:rgba(255,255,255,0.32);transition:color 0.3s;line-height:1;}
.hval.lit{color:#ff6b6b;}
.hval.gold{color:#ffd93d;}
.hlbl{font-size:6.5px;color:rgba(255,255,255,0.2);letter-spacing:0.1em;margin-top:2px;}

/* MIC */
.mic-sec{display:flex;flex-direction:column;align-items:center;padding:24px 20px 10px;position:relative;z-index:4;flex-shrink:0;}
.orb-wrap{position:relative;display:flex;align-items:center;justify-content:center;width:124px;height:124px;cursor:pointer;}
.orb-ring{position:absolute;border-radius:50%;border:1.5px solid rgba(255,107,107,0.3);animation:orbOut 2s ease-out infinite;display:none;}
.orb-ring.r1{width:100px;height:100px;animation-delay:0s;}
.orb-ring.r2{width:116px;height:116px;animation-delay:0.5s;}
.orb-ring.r3{width:135px;height:135px;animation-delay:1s;}
.orb-ring.on{display:block;}
@keyframes orbOut{0%{transform:scale(0.85);opacity:0.6;}100%{transform:scale(1.1);opacity:0;}}
.orb-core{width:82px;height:82px;border-radius:50%;background:radial-gradient(circle at 35% 35%,#1a1a30,#080810);border:1.5px solid rgba(255,255,255,0.1);display:flex;align-items:center;justify-content:center;position:relative;z-index:2;box-shadow:0 8px 32px rgba(0,0,0,0.6),inset 0 1px 0 rgba(255,255,255,0.08);transition:all 0.3s;}
.orb-core.on{border-color:rgba(255,107,107,0.6);box-shadow:0 0 0 1px rgba(255,107,107,0.3),0 8px 40px rgba(255,107,107,0.3),inset 0 1px 0 rgba(255,255,255,0.1);background:radial-gradient(circle at 35% 35%,#2a1520,#0f0810);animation:orbGlow 2s ease-in-out infinite alternate;}
@keyframes orbGlow{from{box-shadow:0 0 0 1px rgba(255,107,107,0.3),0 8px 40px rgba(255,107,107,0.3);}to{box-shadow:0 0 0 1px rgba(255,107,107,0.5),0 8px 60px rgba(255,107,107,0.5);}}
.orb-inner{width:62px;height:62px;border-radius:50%;background:radial-gradient(circle at 40% 30%,rgba(255,255,255,0.05),transparent);display:flex;align-items:center;justify-content:center;}
.orb-emoji{font-size:32px;}
.brain-pulse{font-size:27px;animation:brainPop 0.8s ease-in-out infinite alternate;}
@keyframes brainPop{from{transform:scale(0.9);filter:brightness(0.8);}to{transform:scale(1.1);filter:brightness(1.2);}}
.orb-lbl{position:absolute;bottom:-24px;left:50%;transform:translateX(-50%);white-space:nowrap;font-size:9.5px;font-weight:700;letter-spacing:0.14em;}
.orb-lbl.live{color:#ff6b6b;}
.orb-lbl.idle{color:rgba(255,255,255,0.26);}
.waveform{display:flex;align-items:center;gap:2.5px;height:30px;margin-top:32px;width:100%;}
.wv{width:3px;border-radius:3px;background:rgba(255,255,255,0.1);height:5px;flex-shrink:0;}
.wv.on{background:linear-gradient(to top,#ff6b6b,#ffd93d);animation:wvA 0.6s ease-in-out infinite alternate;}
@keyframes wvA{0%{height:4px;}100%{height:24px;}}
.end-btn{margin-top:10px;background:rgba(255,255,255,0.05);border:1px solid rgba(255,255,255,0.09);color:rgba(255,255,255,0.38);padding:5px 16px;border-radius:18px;font-size:9.5px;cursor:pointer;letter-spacing:0.08em;font-family:'Syne',sans-serif;display:none;}
.end-btn.on{display:block;}

/* TRANSCRIPT BAR */
.tr-bar{margin:0 13px 7px;background:rgba(255,255,255,0.04);border:1px solid rgba(255,255,255,0.07);border-radius:11px;padding:8px 12px;display:none;align-items:center;position:relative;z-index:4;flex-shrink:0;}
.tr-bar.on{display:flex;}
.tr-dot{font-size:9px;color:#ff6b6b;margin-right:7px;}
.tr-txt{font-size:11px;color:rgba(255,255,255,0.42);flex:1;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;}
.ai-spin{font-size:9.5px;color:#ffd93d;margin-left:7px;display:none;}
.ai-spin.on{display:inline;}

/* TABS */
.tab-bar{display:flex;border-bottom:1px solid rgba(255,255,255,0.07);position:relative;z-index:4;flex-shrink:0;}
.tab-btn{flex:1;padding:10px 3px;background:none;border:none;color:rgba(255,255,255,0.26);font-family:'Syne',sans-serif;font-size:9.5px;font-weight:700;letter-spacing:0.04em;cursor:pointer;border-bottom:2px solid transparent;transition:all 0.2s;display:flex;align-items:center;justify-content:center;gap:3px;}
.tab-btn.on{color:#fff;border-bottom-color:#ff6b6b;}
.tbadge{background:#ff6b6b;color:#fff;font-size:7.5px;padding:1px 5px;border-radius:8px;font-weight:800;display:none;}
.tbadge.on{display:inline;}

/* CONTENT */
.content{flex:1;overflow-y:auto;padding:10px 13px 40px;position:relative;z-index:4;}
.tab-panel{display:none;}
.tab-panel.on{display:block;}

/* EMPTY STATE */
.empty-state{display:flex;flex-direction:column;align-items:center;padding:28px 14px;gap:9px;text-align:center;}
.empty-icon{font-size:48px;margin-bottom:5px;}
.empty-title{font-size:18px;font-weight:800;background:linear-gradient(90deg,#ff6b6b,#c77dff);-webkit-background-clip:text;-webkit-text-fill-color:transparent;}
.empty-desc{font-size:11.5px;color:rgba(255,255,255,0.3);line-height:1.7;max-width:260px;}
.ex-chips{margin-top:14px;display:flex;flex-direction:column;gap:6px;width:100%;}
.ex-chip{background:rgba(255,255,255,0.04);border:1px solid rgba(255,255,255,0.07);border-radius:9px;padding:8px 13px;font-size:11.5px;color:rgba(255,255,255,0.35);text-align:left;font-family:'Lora',serif;font-style:italic;}

/* REBUTTAL CARD */
.rcard{background:rgba(8,10,24,0.88);border:1px solid rgba(255,255,255,0.08);border-radius:15px;padding:14px;animation:cardIn 0.4s cubic-bezier(0.34,1.56,0.64,1);position:relative;overflow:hidden;margin-bottom:12px;}
.rcard::before{content:'';position:absolute;top:0;left:0;right:0;height:1px;background:linear-gradient(90deg,var(--cc),transparent);opacity:0.5;}
@keyframes cardIn{from{opacity:0;transform:translateY(16px) scale(0.96);}to{opacity:1;transform:translateY(0) scale(1);}}
.card-top{display:flex;justify-content:space-between;align-items:center;margin-bottom:9px;}
.card-left{display:flex;align-items:center;gap:7px;}
.type-pill{font-size:9.5px;font-weight:700;padding:3px 9px;border-radius:16px;font-family:'Syne',sans-serif;letter-spacing:0.04em;}
.udot{width:6.5px;height:6.5px;border-radius:50%;background:#ff6b6b;animation:udotP 1s ease-in-out infinite;display:none;}
.udot.on{display:block;}
@keyframes udotP{0%,100%{box-shadow:0 0 0 0 rgba(255,107,107,0.6);}50%{box-shadow:0 0 0 4px rgba(255,107,107,0);}}
.card-right{display:flex;align-items:center;gap:7px;}
.card-time{font-size:9.5px;color:rgba(255,255,255,0.2);}
.card-acts{display:flex;gap:5px;}
.act-btn{background:none;border:none;cursor:pointer;font-size:13px;padding:2px;opacity:0.45;transition:opacity 0.2s;}
.act-btn:hover{opacity:1;}
.obj-bubble{background:rgba(255,255,255,0.04);border-radius:8px;padding:8px 10px;margin-bottom:11px;border:1px solid rgba(255,255,255,0.06);font-size:11.5px;color:rgba(255,255,255,0.5);font-style:italic;line-height:1.6;font-family:'Lora',serif;}
.qm{color:rgba(255,255,255,0.26);font-size:17px;font-family:Georgia,serif;vertical-align:middle;}
.div-g{height:1px;background:linear-gradient(90deg,var(--cc) 0%,rgba(255,255,255,0.05) 60%,transparent 100%);margin-bottom:9px;opacity:0.4;}
.reb-lbl{font-size:8.5px;letter-spacing:0.18em;margin-bottom:7px;font-family:'Syne',sans-serif;opacity:0.8;}
.reb-txt{font-size:13.5px;color:rgba(255,255,255,0.9);line-height:1.75;font-family:'Lora',Georgia,serif;}
.urg-ban{margin-top:9px;padding:5px 10px;background:rgba(255,107,107,0.1);border:1px solid rgba(255,107,107,0.25);border-radius:7px;font-size:9.5px;color:#ff6b6b;font-weight:700;letter-spacing:0.05em;display:none;}
.urg-ban.on{display:block;}

/* HISTORY */
.sec-hdr{display:flex;justify-content:space-between;align-items:center;margin-bottom:11px;}
.sec-lbl{font-size:9.5px;color:rgba(255,255,255,0.24);letter-spacing:0.13em;}
.clr-btn{background:none;border:none;color:rgba(255,255,255,0.18);font-size:9.5px;cursor:pointer;font-family:'Syne',sans-serif;letter-spacing:0.05em;}
.hist-empty{text-align:center;padding:40px 20px;color:rgba(255,255,255,0.18);font-size:12px;}

/* TRACKER */
.tracker{display:flex;flex-direction:column;gap:12px;}
.trk-hero{background:rgba(8,10,24,0.88);border:1px solid rgba(255,255,255,0.08);border-radius:15px;padding:18px;text-align:center;}
.wr-circle{position:relative;width:124px;height:124px;margin:0 auto 12px;}
.wr-circle svg{transform:rotate(-90deg);}
.wr-num{position:absolute;top:50%;left:50%;transform:translate(-50%,-50%);font-size:26px;font-weight:800;color:#fff;}
.wr-lbl{font-size:8.5px;color:rgba(255,255,255,0.28);letter-spacing:0.15em;}
.trk-row{display:grid;grid-template-columns:1fr 1fr;gap:9px;}
.trk-card{background:rgba(8,10,24,0.88);border:1px solid rgba(255,255,255,0.08);border-radius:13px;padding:13px;text-align:center;}
.tc-val{font-size:22px;font-weight:800;margin-bottom:3px;}
.tc-lbl{font-size:8.5px;color:rgba(255,255,255,0.28);letter-spacing:0.09em;}
.obj-bk{background:rgba(8,10,24,0.88);border:1px solid rgba(255,255,255,0.08);border-radius:13px;padding:14px;}
.ob-t{font-size:8.5px;color:rgba(255,255,255,0.22);letter-spacing:0.14em;margin-bottom:11px;}
.ob-row{display:flex;align-items:center;gap:9px;margin-bottom:8px;}
.ob-name{font-size:10.5px;color:rgba(255,255,255,0.55);width:68px;flex-shrink:0;}
.ob-bw{flex:1;height:5.5px;background:rgba(255,255,255,0.07);border-radius:3px;overflow:hidden;}
.ob-bar{height:100%;border-radius:3px;transition:width 0.8s ease;}
.ob-cnt{font-size:9.5px;color:rgba(255,255,255,0.28);width:14px;text-align:right;}
.trk-btns{display:grid;grid-template-columns:1fr 1fr;gap:9px;}
.tr-btn{padding:11px;border-radius:11px;border:1px solid rgba(255,255,255,0.1);background:rgba(255,255,255,0.04);color:rgba(255,255,255,0.55);font-family:'Syne',sans-serif;font-size:10.5px;font-weight:700;cursor:pointer;letter-spacing:0.05em;transition:all 0.2s;}
.tr-btn.win{border-color:rgba(29,209,161,0.4);color:#1dd1a1;}
.tr-btn.loss{border-color:rgba(255,107,107,0.4);color:#ff6b6b;}
.tr-btn:active{transform:scale(0.97);}
.ses-note{text-align:center;font-size:9.5px;color:rgba(255,255,255,0.18);letter-spacing:0.05em;}

/* TIPS */
.tips-list{display:flex;flex-direction:column;gap:9px;}
.tips-hdr{font-size:8.5px;color:rgba(255,255,255,0.2);letter-spacing:0.15em;margin-bottom:3px;}
.tip-card{display:flex;gap:11px;align-items:flex-start;background:rgba(8,10,24,0.88);border:1px solid rgba(255,255,255,0.07);border-radius:12px;padding:12px;}
.tip-icon{font-size:22px;min-width:30px;}
.tip-title{font-size:11.5px;font-weight:700;color:rgba(255,255,255,0.8);margin-bottom:3px;}
.tip-desc{font-size:10.5px;color:rgba(255,255,255,0.36);line-height:1.6;}

/* SHARE MODAL */
#share-modal{position:fixed;inset:0;z-index:90;display:none;align-items:flex-end;background:rgba(0,0,0,0.72);}
#share-modal.on{display:flex;}
.sh-sheet{background:#0c0f1e;border-radius:22px 22px 0 0;padding:22px 18px 38px;width:100%;max-width:480px;margin:0 auto;animation:shUp 0.3s cubic-bezier(0.34,1.3,0.64,1);}
@keyframes shUp{from{transform:translateY(100%);}to{transform:translateY(0);}}
.sh-handle{width:34px;height:4px;background:rgba(255,255,255,0.13);border-radius:2px;margin:0 auto 18px;}
.sh-title{font-size:13px;font-weight:700;margin-bottom:5px;color:#fff;}
.sh-text{font-size:12.5px;color:rgba(255,255,255,0.48);font-family:'Lora',serif;font-style:italic;background:rgba(255,255,255,0.04);border-radius:9px;padding:11px;margin-bottom:16px;line-height:1.6;border:1px solid rgba(255,255,255,0.07);}
.sh-btns{display:grid;grid-template-columns:1fr 1fr;gap:9px;}
.sh-btn{padding:12px;border-radius:11px;border:none;font-family:'Syne',sans-serif;font-size:11px;font-weight:700;cursor:pointer;letter-spacing:0.04em;display:flex;align-items:center;justify-content:center;gap:7px;transition:transform 0.15s;}
.sh-btn:active{transform:scale(0.96);}
.sh-copy{background:rgba(255,255,255,0.08);color:#fff;border:1px solid rgba(255,255,255,0.1);}
.sh-sms{background:linear-gradient(135deg,#1dd1a1,#007aff);color:#fff;}
.sh-email{background:linear-gradient(135deg,#ff9f43,#ff6b6b);color:#fff;}
.sh-close{background:rgba(255,255,255,0.04);color:rgba(255,255,255,0.38);border:1px solid rgba(255,255,255,0.08);}

/* TOAST */
.toast{position:fixed;bottom:26px;left:50%;transform:translateX(-50%);background:#0e1e0e;border:1px solid rgba(29,209,161,0.3);border-radius:11px;padding:10px 16px;font-size:11.5px;color:#1dd1a1;display:none;align-items:center;gap:7px;box-shadow:0 8px 32px rgba(0,0,0,0.6);z-index:200;white-space:nowrap;}
.toast.on{display:flex;}
.toast.err{background:#1a0808;border-color:rgba(255,107,107,0.3);color:#ff6b6b;}

/* FLASH */
.flash{position:fixed;inset:0;background:rgba(255,107,107,0.1);z-index:50;pointer-events:none;opacity:0;}
.flash.go{animation:flashGo 0.5s ease-out forwards;}
@keyframes flashGo{0%{opacity:1;}100%{opacity:0;}}
</style>
</head>
<body>
<div id="app">

<!-- SVG BACKGROUND — Professional Sales Scene -->
<svg id="svg-bg" viewBox="0 0 400 700" preserveAspectRatio="xMidYMid slice" xmlns="http://www.w3.org/2000/svg">
  <defs>
    <!-- Room gradients -->
    <linearGradient id="gSky" x1="0" y1="0" x2="0" y2="1">
      <stop offset="0%" stop-color="#050a18"/>
      <stop offset="50%" stop-color="#080e22"/>
      <stop offset="100%" stop-color="#0c1430"/>
    </linearGradient>
    <linearGradient id="gFloor" x1="0" y1="0" x2="0" y2="1">
      <stop offset="0%" stop-color="#0d1628"/>
      <stop offset="100%" stop-color="#060a14"/>
    </linearGradient>
    <linearGradient id="gWall" x1="0" y1="0" x2="0" y2="1">
      <stop offset="0%" stop-color="#090e1e"/>
      <stop offset="100%" stop-color="#0a1224"/>
    </linearGradient>
    <!-- Desk -->
    <linearGradient id="gDesk" x1="0" y1="0" x2="0" y2="1">
      <stop offset="0%" stop-color="#1c2640"/>
      <stop offset="60%" stop-color="#101828"/>
      <stop offset="100%" stop-color="#080e1a"/>
    </linearGradient>
    <linearGradient id="gDeskRefl" x1="0" y1="0" x2="0" y2="1">
      <stop offset="0%" stop-color="#1a2540" stop-opacity="0.6"/>
      <stop offset="100%" stop-color="#080e1a" stop-opacity="0"/>
    </linearGradient>
    <!-- Glass wall -->
    <linearGradient id="gGlass" x1="0" y1="0" x2="1" y2="1">
      <stop offset="0%" stop-color="#b8d4ff" stop-opacity="0.06"/>
      <stop offset="100%" stop-color="#6090ff" stop-opacity="0.02"/>
    </linearGradient>
    <!-- Monitor glows -->
    <radialGradient id="gM1" cx="50%" cy="50%" r="50%">
      <stop offset="0%" stop-color="#2060ff" stop-opacity="1"/>
      <stop offset="100%" stop-color="#061a40" stop-opacity="0"/>
    </radialGradient>
