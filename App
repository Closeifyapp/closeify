      <div class="tip-card"><div class="tip-icon">🔔</div><div><div class="tip-title">Sound alerts</div><div class="tip-desc">A chime plays every time an objection is detected so you never miss one.</div></div></div>
      <div class="tip-card"><div class="tip-icon">📤</div><div><div class="tip-title">Share rebuttals</div><div class="tip-desc">Tap 📤 on any card to send the rebuttal via SMS or email to your team.</div></div></div>
      <div class="tip-card"><div class="tip-icon">📊</div><div><div class="tip-title">Track your win rate</div><div class="tip-desc">After each call tap Log Win or Log Loss in the Stats tab to build your record.</div></div></div>
      <div class="tip-card"><div class="tip-icon">🏠</div><div><div class="tip-title">Add to Home Screen</div><div class="tip-desc">Chrome: tap ⋮ → Add to Home Screen for a fullscreen native app experience.</div></div></div>
    </div>
  </div>

</div><!-- /content -->

<!-- SHARE MODAL -->
<div id="share-modal" onclick="closeShare(event)">
  <div class="sh-sheet">
    <div class="sh-handle"></div>
    <div class="sh-title">📤 Share Rebuttal</div>
    <div class="sh-text" id="shText">—</div>
    <div class="sh-btns">
      <button class="sh-btn sh-copy" onclick="copyReb()">📋 Copy</button>
      <button class="sh-btn sh-sms" onclick="shareSMS()">💬 SMS</button>
      <button class="sh-btn sh-email" onclick="shareEmail()">✉️ Email</button>
      <button class="sh-btn sh-close" onclick="closeShare()">✕ Close</button>
    </div>
  </div>
</div>

<!-- TOAST -->
<div class="toast" id="toast"><span id="toastMsg">Done!</span></div>

<!-- T&C Footer -->
<div style="position:relative;z-index:4;text-align:center;padding:7px 14px 12px;border-top:1px solid rgba(255,255,255,0.05);background:rgba(4,6,20,0.6);flex-shrink:0;">
  <span style="font-size:9px;color:rgba(255,255,255,0.18);font-family:'Syne',sans-serif;letter-spacing:0.04em;">
    By using Closeify you agree to our <a href="https://closeify.app/terms" target="_blank" style="color:#ff6b6b;text-decoration:none;font-weight:700;">Terms &amp; Conditions</a>
    &nbsp;·&nbsp; You are responsible for all required recording consents
  </span>
</div>

<!-- FLASH -->
<div class="flash" id="flashEl"></div>

<script>
const PROMPT=`You are an elite sales coach AI. Detect customer objections and provide powerful rebuttals.
Respond ONLY with valid JSON (no markdown):
{"objection_detected":true/false,"objection_type":"price"|"timing"|"competitor"|"trust"|"need"|"authority"|"other"|null,"objection_summary":"brief summary or null","rebuttal":"confident empathetic 2-3 sentence rebuttal or null","tone":"empathetic"|"assertive"|"curious"|"social_proof","urgency":"high"|"medium"|"low"}
Only flag real buying objections. Keep rebuttals conversational.`;

const TC={
  price:{color:"#ff6b6b",bg:"rgba(255,107,107,0.15)",icon:"💰",label:"Price"},
  timing:{color:"#ffd93d",bg:"rgba(255,217,61,0.15)",icon:"⏰",label:"Timing"},
  competitor:{color:"#c77dff",bg:"rgba(199,125,255,0.15)",icon:"⚔️",label:"Competitor"},
  trust:{color:"#ff9f43",bg:"rgba(255,159,67,0.15)",icon:"🤝",label:"Trust"},
  need:{color:"#48dbfb",bg:"rgba(72,219,251,0.15)",icon:"❓",label:"Need"},
  authority:{color:"#1dd1a1",bg:"rgba(29,209,161,0.15)",icon:"👔",label:"Authority"},
  other:{color:"#a29bfe",bg:"rgba(162,155,254,0.15)",icon:"💬",label:"Objection"},
};
const TM={empathetic:"💙",assertive:"⚡",curious:"🔍",social_proof:"⭐"};

let listening=false,recog=null,callTimer=null,analyzeTO=null;
let dur=0,objCnt=0,rebuttals=[],lastAn="",transcript="";
let history=[];let stats={wins:0,losses:0,objTypes:{}};
let shareText="";

try{history=JSON.parse(localStorage.getItem('clf_h')||'[]');}catch(e){}
try{stats=JSON.parse(localStorage.getItem('clf_s')||'{"wins":0,"losses":0,"objTypes":{}}');}catch(e){}

// AUDIO
function chime(){
  try{
    const ctx=new(window.AudioContext||window.webkitAudioContext)();
    [[880,0],[1108,0.12],[1320,0.24]].forEach(([f,d])=>{
      const o=ctx.createOscillator(),g=ctx.createGain();
      o.connect(g);g.connect(ctx.destination);o.frequency.value=f;o.type='sine';
      const t=ctx.currentTime+d;
      g.gain.setValueAtTime(0,t);g.gain.linearRampToValueAtTime(0.15,t+0.04);g.gain.linearRampToValueAtTime(0,t+0.22);
      o.start(t);o.stop(t+0.25);
    });
  }catch(e){}
}

// WAVEFORM
const wf=document.getElementById('waveform');
for(let i=0;i<26;i++){const b=document.createElement('div');b.className='wv';b.style.animationDelay=`${(i*0.07)%0.8}s`;wf.appendChild(b);}

// SPLASH
function startApp(){const s=document.getElementById('splash');s.classList.add('hide');setTimeout(()=>s.style.display='none',650);}

// LISTEN
function toggleListen(){listening?stopListen():startListen();}

function startListen(){
  const SR=window.SpeechRecognition||window.webkitSpeechRecognition;
  if(!SR){toast('Use Chrome or Safari for mic','err');return;}
  recog=new SR();recog.continuous=true;recog.interimResults=true;recog.lang='en-US';recog._on=true;
  recog.onresult=e=>{
    let interim='',final='';
    for(let i=e.resultIndex;i<e.results.length;i++){
      const t=e.results[i][0].transcript;
      if(e.results[i].isFinal)final+=t+' ';else interim+=t;
    }
    document.getElementById('trTxt').textContent=interim||transcript.slice(-65)||'Listening...';
    document.getElementById('trBar').classList.add('on');
    if(final){transcript+=final;clearTimeout(analyzeTO);analyzeTO=setTimeout(()=>analyze(final.trim()),750);}
  };
  recog.onerror=e=>{if(e.error!=='aborted')toast('Mic: '+e.error,'err');};
  recog.onend=()=>{if(recog._on)recog.start();};
  recog.start();
  listening=true;setOrb(true);
  dur=0;tickTimer();callTimer=setInterval(()=>{dur++;tickTimer();},1000);
}

function stopListen(){
  if(recog){recog._on=false;recog.stop();recog=null;}
  clearInterval(callTimer);listening=false;setOrb(false);
}

function endCall(){
  if(rebuttals.length){
    const s={date:new Date().toLocaleDateString(),time:new Date().toLocaleTimeString([],{hour:'2-digit',minute:'2-digit'}),dur:fmt(dur),count:rebuttals.length,items:rebuttals.map(r=>({type:r.objection_type,sum:r.objection_summary,reb:r.rebuttal}))};
    history.unshift(s);if(history.length>50)history.pop();
    try{localStorage.setItem('clf_h',JSON.stringify(history));}catch(e){}
    renderHistory();
  }
  stopListen();
  document.getElementById('trBar').classList.remove('on');
  toast('📋 Call saved to history');
}

function setOrb(on){
  document.getElementById('orbCore').classList.toggle('on',on);
  document.getElementById('orbEmoji').textContent=on?'🎙️':'🎤';
  document.getElementById('orbLbl').className='orb-lbl '+(on?'live':'idle');
  document.getElementById('orbLbl').textContent=on?'● LIVE':'TAP TO START';
  ['ring1','ring2','ring3'].forEach(id=>document.getElementById(id).classList.toggle('on',on));
  document.getElementById('endBtn').classList.toggle('on',on);
  document.getElementById('timerVal').classList.toggle('lit',on);
  document.querySelectorAll('.wv').forEach(b=>b.classList.toggle('on',on));
}

// ANALYZE
async function analyze(text){
  if(!text.trim()||text===lastAn||text.split(' ').length<4)return;
  lastAn=text;
  document.getElementById('aiSpin').classList.add('on');
  try{
    const res=await fetch('https://api.anthropic.com/v1/messages',{
      method:'POST',headers:{'Content-Type':'application/json'},
      body:JSON.stringify({model:'claude-sonnet-4-20250514',max_tokens:800,system:PROMPT,messages:[{role:'user',content:`Analyze: "${text}"`}]})
    });
    const data=await res.json();
    const raw=data.content?.map(b=>b.text||'').join('').replace(/```json|```/g,'').trim();
    const r=JSON.parse(raw);
    if(r.objection_detected&&r.rebuttal){
      chime();flash();objCnt++;
      document.getElementById('objVal').textContent=objCnt;
      document.getElementById('objVal').classList.add('gold');
      const t=r.objection_type||'other';
      stats.objTypes[t]=(stats.objTypes[t]||0)+1;
      try{localStorage.setItem('clf_s',JSON.stringify(stats));}catch(e){}
      const card={id:Date.now(),...r,ts:new Date().toLocaleTimeString([],{hour:'2-digit',minute:'2-digit'})};
      rebuttals.push(card);addCard(card);switchTab('live');renderBK();
    }
  }catch(e){console.error(e);}
  finally{document.getElementById('aiSpin').classList.remove('on');}
}

// CARDS
function addCard(r){
  document.getElementById('emptyState').style.display='none';
  document.getElementById('rebWrap').style.display='block';
  const cfg=TC[r.objection_type]||TC.other;
  const tone=TM[r.tone]||'';
  const d=document.createElement('div');
  d.className='rcard';d.id='c'+r.id;
  d.style.setProperty('--cc',cfg.color);d.style.borderLeft=`3px solid ${cfg.color}`;
  d.innerHTML=`<div class="card-top">
    <div class="card-left"><div class="type-pill" style="background:${cfg.bg};border:1px solid ${cfg.color}44;color:${cfg.color}">${cfg.icon} ${cfg.label}</div><div class="udot ${r.urgency==='high'?'on':''}"></div></div>
    <div class="card-right"><span class="card-time">${r.ts}</span><div class="card-acts"><button class="act-btn" onclick="openShare(${r.id})">📤</button><button class="act-btn" onclick="dimCard(${r.id})">✕</button></div></div>
  </div>
  <div class="obj-bubble"><span class="qm">"</span>${esc(r.objection_summary||'')}<span class="qm">"</span></div>
  <div class="div-g"></div>
  <div class="reb-lbl" style="color:${cfg.color}">${tone} YOUR REBUTTAL</div>
  <div class="reb-txt">${esc(r.rebuttal||'')}</div>
  <div class="urg-ban ${r.urgency==='high'?'on':''}">🔥 Address this objection now</div>`;
  document.getElementById('rebList').appendChild(d);
  d.scrollIntoView({behavior:'smooth',block:'end'});
  const b=document.getElementById('liveBadge');b.textContent=rebuttals.length;b.classList.add('on');
  document.getElementById('rebCount').textContent=rebuttals.length+' REBUTTAL'+(rebuttals.length!==1?'S':'');
}

function dimCard(id){
  rebuttals=rebuttals.filter(r=>r.id!==id);
  const el=document.getElementById('c'+id);if(el)el.remove();
  if(!rebuttals.length){document.getElementById('rebWrap').style.display='none';document.getElementById('emptyState').style.display='flex';document.getElementById('liveBadge').classList.remove('on');}
  document.getElementById('liveBadge').textContent=rebuttals.length;
  document.getElementById('rebCount').textContent=rebuttals.length+' REBUTTAL'+(rebuttals.length!==1?'S':'');
}

function clearRebuttals(){
  rebuttals=[];document.getElementById('rebList').innerHTML='';
  document.getElementById('rebWrap').style.display='none';document.getElementById('emptyState').style.display='flex';
  document.getElementById('liveBadge').classList.remove('on');document.getElementById('liveBadge').textContent='0';
}

// HISTORY
function renderHistory(){
  const el=document.getElementById('histList');
  document.getElementById('histCount').textContent=history.length+' SESSION'+(history.length!==1?'S':'');
  if(!history.length){el.innerHTML='<div class="hist-empty">No history yet. Complete a call to see logs.</div>';return;}
  el.innerHTML=history.map((s,i)=>`<div class="rcard" style="--cc:#a29bfe;border-left:3px solid #a29bfe;margin-bottom:11px;">
    <div class="card-top">
      <div class="card-left"><div class="type-pill" style="background:rgba(162,155,254,0.15);border:1px solid #a29bfe44;color:#a29bfe">📋 ${s.date}</div></div>
      <div class="card-right"><span class="card-time">${s.time} · ${s.dur}</span><button class="act-btn" onclick="delHist(${i})">✕</button></div>
    </div>
    <div style="display:flex;gap:12px;margin:7px 0 9px;font-size:10.5px;color:rgba(255,255,255,0.38);">
      <span>⚡ ${s.count} objection${s.count!==1?'s':''}</span><span>⏱ ${s.dur}</span>
    </div>
    ${s.items.slice(0,2).map(it=>`<div class="obj-bubble" style="margin-bottom:5px;font-size:10.5px;">${(TC[it.type]||TC.other).icon} <em>${esc(it.sum||'')}</em></div>`).join('')}
    ${s.items.length>2?`<div style="font-size:9.5px;color:rgba(255,255,255,0.22);text-align:center;">+${s.items.length-2} more</div>`:''}
  </div>`).join('');
}

function delHist(i){history.splice(i,1);try{localStorage.setItem('clf_h',JSON.stringify(history));}catch(e){}renderHistory();}
function clearHistory(){history=[];try{localStorage.setItem('clf_h','[]');}catch(e){}renderHistory();}

// TRACKER
function logOutcome(t){
  if(t==='win')stats.wins++;else stats.losses++;
  try{localStorage.setItem('clf_s',JSON.stringify(stats));}catch(e){}
  updateTracker();toast(t==='win'?'✅ Win logged!':'❌ Loss logged.');
}

function updateTracker(){
  const total=stats.wins+stats.losses;
  const pct=total?Math.round(stats.wins/total*100):null;
  document.getElementById('tcWins').textContent=stats.wins;
  document.getElementById('tcLosses').textContent=stats.losses;
  document.getElementById('tcTotal').textContent=total;
  document.getElementById('tcHandled').textContent=Object.values(stats.objTypes).reduce((a,b)=>a+b,0);
  document.getElementById('wrNum').textContent=pct!==null?pct+'%':'—';
  const wv=document.getElementById('winVal');wv.textContent=pct!==null?pct+'%':'—';if(pct!==null)wv.classList.add('gold');
  const c=document.getElementById('winCircle');
  if(c&&pct!==null)c.style.strokeDashoffset=326.7*(1-pct/100);
  renderBK();
}

function renderBK(){
  const el=document.getElementById('bkRows');
  const entries=Object.entries(stats.objTypes).sort((a,b)=>b[1]-a[1]);
  if(!entries.length){el.innerHTML='<div style="color:rgba(255,255,255,0.18);font-size:11px;text-align:center;padding:8px 0;">No data yet</div>';return;}
  const mx=Math.max(...entries.map(e=>e[1]));
  el.innerHTML=entries.map(([type,count])=>{
    const cfg=TC[type]||TC.other;
    return`<div class="ob-row"><div class="ob-name">${cfg.icon} ${cfg.label}</div><div class="ob-bw"><div class="ob-bar" style="width:${Math.round(count/mx*100)}%;background:${cfg.color}"></div></div><div class="ob-cnt">${count}</div></div>`;
  }).join('');
}

// SHARE
function openShare(id){
  const r=rebuttals.find(x=>x.id===id);if(!r)return;
  shareText=r.rebuttal||'';
  document.getElementById('shText').textContent=shareText;
  document.getElementById('share-modal').classList.add('on');
}
function closeShare(e){if(!e||e.target===document.getElementById('share-modal'))document.getElementById('share-modal').classList.remove('on');}
function copyReb(){navigator.clipboard?.writeText(shareText).then(()=>toast('📋 Copied!')).catch(()=>toast('Copy failed','err'));closeShare();}
function shareSMS(){window.open('sms:?body='+encodeURIComponent('Sales rebuttal: '+shareText));closeShare();}
function shareEmail(){window.open('mailto:?subject=Sales+Rebuttal&body='+encodeURIComponent(shareText));closeShare();}

// TABS
function switchTab(t){
  document.querySelectorAll('.tab-btn').forEach(b=>b.classList.remove('on'));
  document.querySelectorAll('.tab-panel').forEach(p=>p.classList.remove('on'));
  document.getElementById('tab-'+t).classList.add('on');
  document.getElementById('panel-'+t).classList.add('on');
}

// HELPERS
function tickTimer(){const m=String(Math.floor(dur/60)).padStart(2,'0');const s=String(dur%60).padStart(2,'0');document.getElementById('timerVal').textContent=m+':'+s;}
function fmt(s){return String(Math.floor(s/60)).padStart(2,'0')+':'+String(s%60).padStart(2,'0');}
function flash(){const f=document.getElementById('flashEl');f.classList.remove('go');void f.offsetWidth;f.classList.add('go');}
function esc(s){return String(s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');}
let tTO=null;
function toast(msg,type='ok'){const t=document.getElementById('toast');document.getElementById('toastMsg').textContent=msg;t.className='toast on'+(type==='err'?' err':'');clearTimeout(tTO);tTO=setTimeout(()=>t.classList.remove('on'),2400);}

// INIT
renderHistory();
updateTracker();
</script>
</body>
</html>
